[Unit]
Description=VerificationStation email verification worker
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=veristation
Group=veristation
WorkingDirectory=/opt/verification-station
Environment=NODE_ENV=production
EnvironmentFile=-/opt/verification-station/.env
ExecStart=/usr/bin/node /opt/verification-station/dist/index.js
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
