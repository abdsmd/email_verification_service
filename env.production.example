# Production-style template (maps to canonical env via `src/config/env-aliases.ts` + `src/config/env.ts`).
# Copy to `.env.production` or merge into your secret store.

NODE_ENV=production

STATION_ID=sg-vps-01
STATION_REGION=singapore
STATION_SECRET=change_me

# Listen (aliases: API_HOST → HOST, API_PORT → PORT)
API_HOST=0.0.0.0
API_PORT=8080

# Concurrency (aliases: MAX_BATCH_SIZE → BATCH_MAX_ITEMS, MAX_CONCURRENT_CHECKS → MAX_CONCURRENCY)
MAX_BATCH_SIZE=100
MAX_CONCURRENT_CHECKS=20
MAX_CONCURRENT_PER_DOMAIN=2
MAX_CONCURRENT_PER_PROVIDER=3

DNS_TIMEOUT_MS=3000
SMTP_TIMEOUT_MS=8000
SMTP_MAX_MX_ATTEMPTS=3

SMTP_PROBING_ENABLED=true
CATCH_ALL_ENABLED=true

HELO_DOMAIN=verify.yourdomain.com
MAIL_FROM=verify@yourdomain.com

CACHE_ENABLED=true
CACHE_BACKEND=memory
SQLITE_PATH=/var/lib/verification-station/cache.sqlite

# Seconds → internal *CacheTtlMs (see env-aliases)
MX_CACHE_TTL_SECONDS=86400
NO_MX_CACHE_TTL_SECONDS=86400
CATCHALL_CACHE_TTL_SECONDS=21600
TEMP_FAILURE_CACHE_TTL_SECONDS=1800
MAILBOX_VALID_CACHE_TTL_SECONDS=3600
MAILBOX_INVALID_CACHE_TTL_SECONDS=21600

PROVIDER_COOLDOWN_ENABLED=true
PROVIDER_COOLDOWN_BASE_SECONDS=900
PROVIDER_COOLDOWN_MAX_SECONDS=86400

LOG_LEVEL=info
LOG_FULL_EMAIL=false

DISPOSABLE_MODE=risky
ROLE_ACCOUNT_MODE=risky
