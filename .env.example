# For a full ops-style block (API_HOST, MAX_BATCH_SIZE, *_SECONDS, etc.) see `env.production.example`.

NODE_ENV=production
# Default: loopback only — not reachable from other hosts. Use HOST=0.0.0.0 for Docker / bind all interfaces.
HOST=127.0.0.1
PORT=8090
STATION_ID=verification-station
# STATION_REGION=singapore
LOG_LEVEL=info
MAIL_FROM_DOMAIN=invalid.local
DATA_DIR=src/data
MAX_CONCURRENCY=20
# /v1/verify/batch: max items (after Zod), hard cap 10000; parallel domain groups
# BATCH_MAX_ITEMS=500
# BATCH_DOMAIN_CONCURRENCY=8

RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
# Optional: multi-tenant API keys (JSON array). If set, only these bearers work — not STATION_SECRET/API_KEY alone.
# Example: [{"bearer":"tk_live_abc","id":"acme","rateLimitRpm":60},{"bearer":"tk_live_def","id":"contoso","rateLimitRpm":120}]
# TENANT_KEYS_JSON=
# VERIFICATION_EXPLAIN_ENABLED=true
# (Adds explain + confidence 0–100 in JSON when true; verdict confidence, not inbox placement.)
# API_DOCS_ENABLED=false
# (OpenAPI 3 + Swagger UI at /v1/docs when true; same auth as other protected routes.)
# IDEMPOTENCY_TTL_MS=3600000
# IDEMPOTENCY_MAX_ENTRIES=10000
# SLOW_REQUEST_THRESHOLD_MS=5000
# METRICS_LATENCIES_MAX=2000
# AUDIT_LOG_PATH=./data/audit.log
# Shared Redis for rate limit + idempotency across multiple app instances (optional)
# REDIS_URL=redis://127.0.0.1:6379
# Async in-process verify: POST /v1/verify/jobs (202), GET /v1/verify/jobs/:id; optional callbackUrl + signed webhook
# ASYNC_VERIFY_JOBS_ENABLED=false
# ASYNC_JOBS_MAX=2000
# WEBHOOK_SIGNING_SECRET=
# MX_RCPT_TRANSIENT_FALLBACK_ENABLED=false
# MX_RCPT_TRANSIENT_FALLBACK_MAX_EXTRA=1
# VERIFICATION_SIGNALS_ENABLED=true
# SMTP_RETRY_BIG_PROVIDER_MULT=1.25
# (default 1 = same delay as other providers; raise to slow reconnects when throttled)
DNS_TIMEOUT_MS=5000
DNS_RETRIES=1

SMTP_CONNECT_TIMEOUT_MS=12000
SMTP_COMMAND_TIMEOUT_MS=10000
SMTP_BANNER_READ_TIMEOUT_MS=15000
SMTP_RETRIES=1
SMTP_RETRY_BASE_DELAY_MS=200
SMTP_USE_STARTTLS=true

DNS_CACHE_MAX=5000
DNS_CACHE_TTL_MS=300000

LAYER_CACHE_MAX=5000
# mx: — jitter between min/max (ms)
MX_CACHE_TTL_MIN_MS=21600000
MX_CACHE_TTL_MAX_MS=86400000
DOMAIN_EXISTS_CACHE_TTL_MS=86400000
DEAD_DOMAIN_CACHE_TTL_MS=86400000
DISPOSABLE_CACHE_TTL_MIN_MS=604800000
DISPOSABLE_CACHE_TTL_MAX_MS=2592000000
CATCHALL_CACHE_TTL_MIN_MS=21600000
CATCHALL_CACHE_TTL_MAX_MS=86400000
PROVIDER_COOLDOWN_CACHE_TTL_MAX_MS=604800000
SMTP_HEALTH_CACHE_TTL_MIN_MS=900000
SMTP_HEALTH_CACHE_TTL_MAX_MS=3600000
PERSISTENT_MX_CACHE_TTL_MIN_MS=21600000
PERSISTENT_MX_CACHE_TTL_MAX_MS=86400000
ROLE_PREFIX_CACHE_TTL_MS=2592000000
RESULT_CACHE_MAX=2000
RESULT_CACHE_TTL_MS=60000
# DISPOSABLE_LIST_PATH=./extra-disposable.txt
# In-process list sync (node-cron; outbound HTTPS to raw.githubusercontent.com). Unset = enabled in production only.
# DISPOSABLE_LIST_CRON_ENABLED=true
# DISPOSABLE_LIST_CRON_SCHEDULE=15 6 * * *
# DISPOSABLE_LIST_CRON_TIMEZONE=UTC
# disposable scoring: "risky" (default) or "undeliverable" per scoring.service
# DISPOSABLE_DELIVERABILITY=risky
PROVIDER_BLOCK_COOLDOWN_MS=1800000
# Spacing between SMTP probes to the same big provider (0 = off). Gmail/Outlook/Yahoo also use
# MAJOR_FREE_MAIL_PROVIDERS_MIN_INTERVAL_MS as a floor when this is > 0
BIG_PROVIDER_SMTP_MIN_INTERVAL_MS=4000
# MAJOR_FREE_MAIL_PROVIDERS_MIN_INTERVAL_MS=5000
# SMTP_SESSION_MAX_MS=90000
# HTTP_REQUEST_TIMEOUT_MS=180000
# HTTP_CONNECTION_TIMEOUT_MS=0
# SHUTDOWN_GRACE_MS=30000
# LOG_FULL_EMAIL=false
CORS_ENABLED=false
# Installable PWA (manifest, service worker) from ./public; set false to serve API only
# PWA_ENABLED=true
# Auth: `Authorization: Bearer <token>` (prefer STATION_SECRET; API_KEY is legacy)
# STATION_SECRET=rotate-me
# HMAC: X-Timestamp + X-Signature (hex HMAC-SHA256 of "timestamp." + raw body) + X-Request-Id; optional second factor
# HMAC_SECRET=shared-with-master
# HMAC_SKEW_MS=300000
# HMAC_REPLAY_TTL_MS=600000
# Body size (bytes, default 1MB)
# REQUEST_BODY_MAX_BYTES=1048576
# Behind a reverse proxy (client IP for allowlist)
# TRUST_PROXY=false
# Comma-separated IPs; empty = no restriction
# IP_ALLOWLIST=127.0.0.1,::1
CACHE_BACKEND=memory
# CACHE_BACKEND=sqlite
# SQLITE_PATH=./data/verification-station.db
METRICS_ENABLED=true
# Persist provider escalated cooldowns (uses same DB file as cache when set)
# PROVIDER_COOLDOWN_PERSIST=true
# Per-MX A/AAAA resolution (ms)
# MX_HOST_DNS_TIMEOUT_MS=5000
# Count toward mx_unreachable_persistent (timeouts never count; threshold >= 2)
# MX_PERSISTENT_FAILURE_THRESHOLD=5
# MX_PERSISTENT_FAILURE_WINDOW_MS=3600000
