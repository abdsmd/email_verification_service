# Copy to project root as `.env` and adjust (docker compose reads ../.env from repo root)
# Values below match docker-compose defaults for data on the host (./data -> /app/data).

NODE_ENV=production
# Overridden by docker-compose to 0.0.0.0 (required for port mapping). Do not use 127.0.0.1 in the container for published ports.
HOST=0.0.0.0
PORT=8090

# Required for protected routes
STATION_SECRET=change-me-in-production

# Identity for SMTP probes (set real values)
HELO_DOMAIN=mail.example.com
MAIL_FROM=verify@example.com
# or: MAIL_FROM_DOMAIN=example.com

# Already set by docker-compose.yml (override only if you know what you are doing)
# DATA_DIR=data
# CACHE_BACKEND=sqlite
# SQLITE_PATH=/app/data/verification-station.db
# PROVIDER_COOLDOWN_PERSIST=true

# Optional: extra disposable list on host
# DISPOSABLE_LIST_PATH=/app/data/extra-disposable.txt

# Behind a reverse proxy
# TRUST_PROXY=true
# RATE_LIMIT_MAX=120
